import { describe, it, expect, beforeEach, vi } from 'vitest'
import { testDocument, findBlockById, createTestDocumentCopy } from '../test-data'
import { Block, BlockID } from '../../lib/types'

// Mock TipTap Editor for testing HTML roundtrip
class MockTipTapEditor {
  private content: string = ''
  
  // This is where the bug might occur - extra P tags getting added
  setHTML(html: string): void {
    this.content = html
  }
  
  getHTML(): string {
    // BUG: TipTap might wrap content in extra P tags
    if (this.content && !this.content.startsWith('<p>')) {
      return `<p>${this.content}</p>` // This is the bug!
    }
    return this.content
  }
  
  // Simulate editor modifications
  makeWordBold(word: string): void {
    this.content = this.content.replace(
      new RegExp(`\\b${word}\\b`, 'g'),
      `<strong>${word}</strong>`
    )
  }
}

// Mock the editor service that handles block loading/saving
class MockEditorService {
  private editor: MockTipTapEditor
  private blocks: Map<BlockID, Block> = new Map()
  
  constructor() {
    this.editor = new MockTipTapEditor()
  }
  
  // Load block into editor
  loadBlockIntoEditor(block: Block): void {
    this.editor.setHTML(block.html || block.canonical)
  }
  
  // Get HTML from editor (this is where extra P tags might be added)
  getHTMLFromEditor(): string {
    return this.editor.getHTML()
  }
  
  // Save editor content back to block
  saveEditorContentToBlock(block: Block): Block {
    return {
      ...block,
      html: this.getHTMLFromEditor(),
      updatedAt: new Date()
    }
  }
  
  // Make a word bold in the editor
  makeWordBold(word: string): void {
    this.editor.makeWordBold(word)
  }
  
  // Initialize with test data
  initializeBlocks(blocks: Block[]): void {
    this.blocks.clear()
    const flattenBlocks = (blockList: Block[]) => {
      blockList.forEach(block => {
        this.blocks.set(block.id, block)
        if (block.children) {
          flattenBlocks(block.children)
        }
      })
    }
    flattenBlocks(blocks)
  }
  
  getBlock(id: BlockID): Block | undefined {
    return this.blocks.get(id)
  }
}

describe('Editor HTML Roundtrip Tests - Extra P Tag Bug Detection', () => {
  let editorService: MockEditorService
  let originalBlocks: Block[]

  beforeEach(() => {
    editorService = new MockEditorService()
    originalBlocks = createTestDocumentCopy()
    editorService.initializeBlocks(originalBlocks)
  })

  describe('Load Block → Editor → Save Without Changes', () => {
    it('should NOT add extra P tags when loading/saving without changes', () => {
      // Test with a block that has existing HTML
      const block = findBlockById(originalBlocks, 'block_p1' as BlockID)!
      const originalHTML = block.html!
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Save without making any changes
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // HTML should remain exactly the same
      expect(savedBlock.html).toBe(originalHTML)
      expect(savedBlock.html).not.toMatch(/^<p><p>.*<\/p><\/p>$/) // No double P tags
      expect(savedBlock.html).not.toMatch(/<p><strong>longer<\/strong><\/p>/) // No extra P wrapper
    })
    
    it('should preserve complex nested HTML without modification', () => {
      const quoteBlock = findBlockById(originalBlocks, 'block_quote' as BlockID)!
      const originalHTML = quoteBlock.html!
      
      // Original: <blockquote><strong><em>This is a quoted insight.</em></strong></blockquote>
      expect(originalHTML).toBe('<blockquote><strong><em>This is a quoted insight.</em></strong></blockquote>')
      
      // Load into editor
      editorService.loadBlockIntoEditor(quoteBlock)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(quoteBlock)
      
      // Should be identical
      expect(savedBlock.html).toBe(originalHTML)
      expect(savedBlock.html).not.toMatch(/^<p><blockquote>/) // No P wrapper around blockquote
    })
    
    it('should handle blocks with inline formatting correctly', () => {
      const block = findBlockById(originalBlocks, 'block_li1' as BlockID)!
      const originalHTML = block.html!
      
      // Original: <strong>Improves</strong> <em>reusability</em>
      expect(originalHTML).toBe('<strong>Improves</strong> <em>reusability</em>')
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // Should preserve exact formatting
      expect(savedBlock.html).toBe(originalHTML)
      expect(savedBlock.html).not.toMatch(/^<p><strong>/) // No P wrapper
    })
    
    it('should NOT wrap plain text blocks in extra P tags', () => {
      const headerBlock = findBlockById(originalBlocks, 'block_h1_1' as BlockID)!
      const originalHTML = headerBlock.html!
      
      // Original: "First Header 1" (plain text)
      expect(originalHTML).toBe('First Header 1')
      
      // Load into editor
      editorService.loadBlockIntoEditor(headerBlock)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(headerBlock)
      
      // This test will FAIL due to the bug - editor adds P tags
      expect(savedBlock.html).toBe(originalHTML)
      expect(savedBlock.html).not.toBe('<p>First Header 1</p>') // Should NOT add P wrapper
    })
  })

  describe('Load Block → Editor → Make Small Change → Save', () => {
    it('should preserve existing HTML structure when making word bold', () => {
      const block = findBlockById(originalBlocks, 'block_p1' as BlockID)!
      const originalHTML = block.html!
      
      // Original: This is a <strong>longer</strong> <em>paragraph</em> with <u>various</u> <s>inline</s> <code>formats</code>.
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Make the word "paragraph" bold (it's already in <em> tags)
      editorService.makeWordBold('paragraph')
      
      // Save the change
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // Should have nested <strong> inside <em>
      expect(savedBlock.html).toContain('<em><strong>paragraph</strong></em>')
      
      // Should NOT have extra P wrapper around the whole thing
      expect(savedBlock.html).not.toMatch(/^<p>This is a <strong>longer<\/strong>.*<\/p>$/)
      
      // Should preserve other formatting
      expect(savedBlock.html).toContain('<strong>longer</strong>')
      expect(savedBlock.html).toContain('<u>various</u>')
      expect(savedBlock.html).toContain('<s>inline</s>')
      expect(savedBlock.html).toContain('<code>formats</code>')
    })
    
    it('should handle bold addition without breaking existing structure', () => {
      const block = findBlockById(originalBlocks, 'block_li2' as BlockID)!
      const originalHTML = block.html!
      
      // Original: <strong>Reduces</strong> <em>duplication</em>
      expect(originalHTML).toBe('<strong>Reduces</strong> <em>duplication</em>')
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Make "duplication" bold too (it's currently in <em>)
      editorService.makeWordBold('duplication')
      
      // Save the change
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // Should preserve existing bold and add new bold
      expect(savedBlock.html).toContain('<strong>Reduces</strong>')
      expect(savedBlock.html).toContain('<em><strong>duplication</strong></em>')
      
      // Should NOT wrap in P tags
      expect(savedBlock.html).not.toMatch(/^<p><strong>Reduces<\/strong>/)
    })
    
    it('should maintain blockquote structure when making internal changes', () => {
      const quoteBlock = findBlockById(originalBlocks, 'block_quote' as BlockID)!
      const originalHTML = quoteBlock.html!
      
      // Original: <blockquote><strong><em>This is a quoted insight.</em></strong></blockquote>
      
      // Load into editor
      editorService.loadBlockIntoEditor(quoteBlock)
      
      // Make "insight" bold (it's already in <strong><em>)
      editorService.makeWordBold('insight')
      
      // Save the change
      const savedBlock = editorService.saveEditorContentToBlock(quoteBlock)
      
      // Should preserve blockquote structure
      expect(savedBlock.html).toMatch(/^<blockquote>/)
      expect(savedBlock.html).toMatch(/<\/blockquote>$/)
      
      // Should NOT wrap blockquote in P tags
      expect(savedBlock.html).not.toMatch(/^<p><blockquote>/)
      
      // Should have the bold change
      expect(savedBlock.html).toContain('<strong>insight</strong>')
    })
  })

  describe('Common Editor HTML Corruption Scenarios', () => {
    it('should not duplicate nested formatting tags', () => {
      const block = findBlockById(originalBlocks, 'block_p1' as BlockID)!
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Make an already bold word bold again (common user mistake)
      editorService.makeWordBold('longer') // This is already <strong>longer</strong>
      
      // Save the change
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // Should NOT create nested <strong><strong>
      expect(savedBlock.html).not.toContain('<strong><strong>')
      expect(savedBlock.html).toContain('<strong>longer</strong>')
    })
    
    it('should handle empty content without adding placeholder P tags', () => {
      const emptyBlock: Block = {
        id: 'empty-block' as BlockID,
        canonical: '',
        html: '',
        createdBy: 'test-user',
        createdAt: new Date(),
        updatedBy: 'test-user',
        updatedAt: new Date()
      }
      
      // Load empty block into editor
      editorService.loadBlockIntoEditor(emptyBlock)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(emptyBlock)
      
      // Should NOT add placeholder P tags
      expect(savedBlock.html).toBe('')
      expect(savedBlock.html).not.toBe('<p></p>')
      expect(savedBlock.html).not.toBe('<p><br></p>')
    })
    
    it('should preserve whitespace and special characters', () => {
      const specialBlock: Block = {
        id: 'special-block' as BlockID,
        canonical: 'Text with   spaces & special chars',
        html: 'Text with   spaces &amp; special chars',
        createdBy: 'test-user',
        createdAt: new Date(),
        updatedBy: 'test-user',
        updatedAt: new Date()
      }
      
      // Load into editor
      editorService.loadBlockIntoEditor(specialBlock)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(specialBlock)
      
      // Should preserve HTML entities and whitespace
      expect(savedBlock.html).toBe('Text with   spaces &amp; special chars')
      expect(savedBlock.html).not.toBe('<p>Text with   spaces &amp; special chars</p>')
    })
  })

  describe('HTML Consistency Validation', () => {
    it('should maintain consistent HTML structure across load/save cycles', () => {
      const testBlocks = [
        findBlockById(originalBlocks, 'block_p1' as BlockID)!,
        findBlockById(originalBlocks, 'block_quote' as BlockID)!,
        findBlockById(originalBlocks, 'block_li1' as BlockID)!,
        findBlockById(originalBlocks, 'block_h1_1' as BlockID)!
      ]
      
      testBlocks.forEach(block => {
        const originalHTML = block.html
        
        // Load into editor and save 3 times (simulate multiple edit sessions)
        let currentBlock = block
        for (let i = 0; i < 3; i++) {
          editorService.loadBlockIntoEditor(currentBlock)
          currentBlock = editorService.saveEditorContentToBlock(currentBlock)
        }
        
        // HTML should be identical after multiple load/save cycles
        expect(currentBlock.html).toBe(originalHTML)
      })
    })
    
    it('should detect and report HTML structure changes', () => {
      const block = findBlockById(originalBlocks, 'block_p1' as BlockID)!
      const originalHTML = block.html!
      
      // Load into editor
      editorService.loadBlockIntoEditor(block)
      
      // Save without changes
      const savedBlock = editorService.saveEditorContentToBlock(block)
      
      // Create a detailed report of any HTML changes
      const htmlChanged = savedBlock.html !== originalHTML
      const addedPTags = savedBlock.html?.includes('<p>') && !originalHTML?.includes('<p>')
      const extraNesting = savedBlock.html?.split('<').length !== originalHTML?.split('<').length
      
      // This helps identify the specific type of corruption
      if (htmlChanged) {
        console.log('HTML Corruption Detected:')
        console.log('Original:', originalHTML)
        console.log('After Editor:', savedBlock.html)
        console.log('Added P tags:', addedPTags)
        console.log('Extra nesting:', extraNesting)
      }
      
      expect(htmlChanged).toBe(false)
    })
  })
})