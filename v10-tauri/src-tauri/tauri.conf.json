{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mohio Desktop Prototype",
  "version": "0.1.0",
  "identifier": "com.mohio.desktop.prototype",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mohio Desktop Prototype",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": false
  }
}
